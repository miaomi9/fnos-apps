#!/bin/sh
APP_DIR="${TRIM_APPDEST}"
APP_DATA_DIR=$1

CONFIG_FILE="$APP_DATA_DIR/smartdns.conf"
DATA_DIR="$APP_DATA_DIR/data"

mkdir -p "$DATA_DIR"

if [ ! -f "$CONFIG_FILE" ]; then
    cp "$APP_DIR/config/smartdns.conf" "$CONFIG_FILE"
fi

cd "$APP_DIR" || exit 1
exec "$APP_DIR/runtime/run-smartdns" -f -c "$CONFIG_FILE"
