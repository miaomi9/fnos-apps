#!/bin/bash

generate_nextauth_secret() {
    if command -v openssl >/dev/null 2>&1; then
        openssl rand -hex 32
    else
        uuidgen | tr -d '-'
    fi
}

service_postinst() {
    local env_file="${TRIM_APPDEST}/docker/.env"
    local nextauth_secret=""

    mkdir -p "${TRIM_PKGVAR}/pgdata" 2>/dev/null || true
    mkdir -p "${TRIM_PKGVAR}/data" 2>/dev/null || true

    if [ -f "$env_file" ]; then
        nextauth_secret=$(grep '^NEXTAUTH_SECRET=' "$env_file" | awk -F '=' '{print $2}' | tr -d '\r')
    fi

    if [ -z "$nextauth_secret" ]; then
        nextauth_secret=$(generate_nextauth_secret)
    fi

    echo "NEXTAUTH_SECRET=${nextauth_secret}" > "$env_file"
    chmod 600 "$env_file"
    install_log "Wrote docker .env: NEXTAUTH_SECRET=<generated>"
}

service_preupgrade() {
    if [ -f "${TRIM_APPDEST}/docker/.env" ]; then
        cp "${TRIM_APPDEST}/docker/.env" "${TRIM_PKGVAR}/.env.bak"
    fi
}

service_restore() {
    if [ -f "${TRIM_PKGVAR}/.env.bak" ]; then
        cp "${TRIM_PKGVAR}/.env.bak" "${TRIM_APPDEST}/docker/.env"
        rm -f "${TRIM_PKGVAR}/.env.bak"
    fi
}
