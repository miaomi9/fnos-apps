#!/bin/bash

generate_secret_key() {
    if command -v openssl >/dev/null 2>&1; then
        openssl rand -hex 32
    else
        uuidgen | tr -d '-'
    fi
}

service_postinst() {
    local env_file="${TRIM_APPDEST}/docker/.env"
    local secret_key=""

    mkdir -p "${TRIM_PKGVAR}/config" 2>/dev/null || true
    mkdir -p "${TRIM_PKGVAR}/icons" 2>/dev/null || true

    if [ -f "$env_file" ]; then
        secret_key=$(grep '^SECRET_ENCRYPTION_KEY=' "$env_file" | awk -F '=' '{print $2}' | tr -d '\r')
    fi

    if [ -z "$secret_key" ]; then
        secret_key=$(generate_secret_key)
    fi

    echo "SECRET_ENCRYPTION_KEY=${secret_key}" > "$env_file"
    install_log "Wrote docker .env: SECRET_ENCRYPTION_KEY=<generated>"
}

service_preupgrade() {
    if [ -f "${TRIM_APPDEST}/docker/.env" ]; then
        cp "${TRIM_APPDEST}/docker/.env" "${TRIM_PKGVAR}/.env.bak"
    fi
}

service_restore() {
    if [ -f "${TRIM_PKGVAR}/.env.bak" ]; then
        cp "${TRIM_PKGVAR}/.env.bak" "${TRIM_APPDEST}/docker/.env"
        rm -f "${TRIM_PKGVAR}/.env.bak"
    fi
}
