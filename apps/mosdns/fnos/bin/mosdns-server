#!/bin/sh
APP_DIR="${TRIM_APPDEST}"
APP_DATA_DIR=$1

CONFIG_FILE="$APP_DATA_DIR/config.yaml"
CN_DOMAINS_FILE="$APP_DATA_DIR/cn_domains.txt"

if [ ! -f "$CONFIG_FILE" ]; then
    cp "$APP_DIR/config/config.yaml" "$CONFIG_FILE"
fi

if [ ! -f "$CN_DOMAINS_FILE" ]; then
    cp "$APP_DIR/config/cn_domains.txt" "$CN_DOMAINS_FILE"
fi

cd "$APP_DATA_DIR" || exit 1
exec "$APP_DIR/mosdns" start -c "$CONFIG_FILE"
