#!/bin/bash

service_postinst() {
    mkdir -p "${TRIM_PKGVAR}/data" 2>/dev/null || true
    mkdir -p "${TRIM_PKGVAR}/letsencrypt" 2>/dev/null || true
}

COMPOSE_FILE="${TRIM_APPDEST}/docker/docker-compose.yaml"
PORT_SAVE="${TRIM_PKGVAR}/.port"
HTTP_PORT_SAVE="${TRIM_PKGVAR}/.http_port"
HTTPS_PORT_SAVE="${TRIM_PKGVAR}/.https_port"

apply_port() {
    local port="$1"
    [ -z "$port" ] && return
    sed -i 's/"[^"]*:81"/"'"${port}"':81"/' "$COMPOSE_FILE"
    echo "${port}" > "$PORT_SAVE"
    install_log "Patched docker-compose.yaml: admin port=${port}"
}

apply_http_port() {
    local port="$1"
    [ -z "$port" ] && return
    sed -i 's/"[^"]*:80"/"'"${port}"':80"/' "$COMPOSE_FILE"
    echo "${port}" > "$HTTP_PORT_SAVE"
    install_log "Patched docker-compose.yaml: http port=${port}"
}

apply_https_port() {
    local port="$1"
    [ -z "$port" ] && return
    sed -i 's/"[^"]*:443"/"'"${port}"':443"/' "$COMPOSE_FILE"
    echo "${port}" > "$HTTPS_PORT_SAVE"
    install_log "Patched docker-compose.yaml: https port=${port}"
}

service_postupgrade() {
    [ -f "$PORT_SAVE" ] && apply_port "$(cat "$PORT_SAVE")"
    [ -f "$HTTP_PORT_SAVE" ] && apply_http_port "$(cat "$HTTP_PORT_SAVE")"
    [ -f "$HTTPS_PORT_SAVE" ] && apply_https_port "$(cat "$HTTPS_PORT_SAVE")"
}

service_postconfig() {
    [ -n "${wizard_port:-}" ] && apply_port "${wizard_port}"
    [ -n "${wizard_http_port:-}" ] && apply_http_port "${wizard_http_port}"
    [ -n "${wizard_https_port:-}" ] && apply_https_port "${wizard_https_port}"
}
